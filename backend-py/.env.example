# Same secret as Next.js so JWTs issued on either side are interchangeable.
NEXTAUTH_SECRET=

# OpenAI — gpt-4o-mini only.
OPENAI_API_KEY=

# Google OAuth (same app as Next.js).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Prisma points at the same SQLite file Next.js uses.
# Path is relative to backend-py/prisma/schema.prisma.
# Next.js's dev.db actually lives at prisma/prisma/dev.db (nested).
DATABASE_URL=file:../../prisma/prisma/dev.db
